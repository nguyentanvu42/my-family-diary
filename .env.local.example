# ── Supabase PostgreSQL ─────────────────────────────────────
# Lấy từ: Supabase Dashboard → Project Settings → Database

# Transaction mode (pooled) — cho Prisma runtime queries
# Format: postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true
POSTGRES_PRISMA_URL=

# Direct connection — cho prisma migrate (bypass pooler)
# Format: postgresql://postgres.[ref]:[password]@db.[ref].supabase.co:5432/postgres
POSTGRES_URL_NON_POOLING=

# ── NextAuth ─────────────────────────────────────────────────
# Tạo random secret: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
# Mật khẩu dùng chung cho tất cả tài khoản (Credentials login)
ADMIN_PASSWORD=

# ── Vercel Blob ──────────────────────────────────────────────
# Lấy từ: Vercel Dashboard → Storage → Blob → .env.local
BLOB_READ_WRITE_TOKEN=
